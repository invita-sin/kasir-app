generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cabang {
  id         String     @id @default(cuid())
  name       String
  address    String?
  phone      String?
  appName    String     @default("Kasir App")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  users      User[]
  products   Product[]
  categories Category[]
}

model User {
  id           String   @id @default(cuid())
  cabangId     String?
  cabang       Cabang?  @relation(fields: [cabangId], references: [id])
  username     String   @unique
  password     String
  name         String
  role         String   @default("KASIR")
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  cabangId  String
  cabang    Cabang    @relation(fields: [cabangId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@unique([cabangId, name])
}

model Product {
  id          String     @id @default(cuid())
  cabangId    String
  cabang      Cabang     @relation(fields: [cabangId], references: [id])
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name        String
  sku         String
  description String?
  price       Float
  cost        Float      @default(0)
  stock       Int        @default(0)
  minStock    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  stockIn     StockIn[]
  stockOut    StockOut[]
  saleItems   SaleItem[]

  @@unique([cabangId, sku])
}

model StockIn {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  note      String?
  createdAt DateTime @default(now())
}

model StockOut {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  note      String?
  createdAt DateTime @default(now())
}

model Sale {
  id             String     @id @default(cuid())
  total          Float
  paymentMethod  String     @default("tunai")
  status         String     @default("active")
  voidedAt       DateTime?
  voidedReason   String?
  createdAt      DateTime   @default(now())
  items          SaleItem[]

  @@index([createdAt])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  cabangId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([cabangId])
  @@index([createdAt])
  @@index([action])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  cost      Float    @default(0)
}
