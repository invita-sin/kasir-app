generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cabang {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  appName   String   @default("Kasir App")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  products  Product[]
}

model User {
  id           String   @id @default(cuid())
  cabangId     String?
  cabang       Cabang?  @relation(fields: [cabangId], references: [id])
  username     String   @unique
  password     String
  name         String
  role         String   @default("KASIR")
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  cabangId    String
  cabang      Cabang   @relation(fields: [cabangId], references: [id])
  name        String
  sku         String
  description String?
  price       Float
  stock       Int      @default(0)
  minStock    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stockIn     StockIn[]
  stockOut    StockOut[]
  saleItems   SaleItem[]

  @@unique([cabangId, sku])
}

model StockIn {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  note      String?
  createdAt DateTime @default(now())
}

model StockOut {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  note      String?
  createdAt DateTime @default(now())
}

model Sale {
  id           String     @id @default(cuid())
  total        Float
  status       String     @default("active")
  voidedAt     DateTime?
  voidedReason String?
  createdAt    DateTime   @default(now())
  items        SaleItem[]

  @@index([createdAt])
  @@index([status])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}
